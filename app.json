{
  "expo": {
    "name": "RepairPro",
    "slug": "repairpro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourname.repairpro",
      "infoPlist": {
        "NSCameraUsageDescription": "RepairPro needs camera access to take job photos.",
        "NSPhotoLibraryUsageDescription": "RepairPro needs photo library access to attach job photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#2563EB"
      },
      "package": "com.yourname.repairpro",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#2563EB"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "RepairPro needs access to photos to attach job photos."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
